def init_oracle():
    try:
        oracledb.init_oracle_client(lib_dir=ORACLE_CLIENT_DIR)
    except Exception:
        pass

def run_query(conn, sql: str, params=None) -> pd.DataFrame:
    with conn.cursor() as cur:
        cur.execute(sql, params or {})
        rows = cur.fetchall()
        cols = [d[0] for d in cur.description]
    return pd.DataFrame(rows, columns=cols)

def normalize_class(v) -> str:
    s = str(v).strip().upper()
    if s in {"CM", "CREDIT MEMO"}:
        return "Credit Memo"
    if s in {"DM", "DEBIT MEMO"}:
        return "Debit Memo"
    if s in {"INV", "INVOICE"}:
        return "Invoice"
    return str(v).strip()

def is_group(v) -> bool:
    return "GROUP" in str(v).upper()

def to_num(v) -> float:
    try:
        if pd.isna(v):
            return 0.0
        return round(float(v), 2)
    except Exception:
        return 0.0


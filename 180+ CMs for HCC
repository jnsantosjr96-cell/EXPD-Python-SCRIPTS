def update_concat_for_unmatched(accounts: List[str]) -> None:
    if not CONCAT_PATH.exists():
        return

    wb = load_workbook(CONCAT_PATH)
    ws = wb.active
    template_formula = ws["B2"].value
    max_clear = max(ws.max_row, len(accounts) + 10)

    for r in range(2, max_clear + 1):
        ws[f"A{r}"] = None
        if r > 2:
            ws[f"B{r}"] = None

    for i, acc in enumerate(accounts, start=2):
        ws[f"A{i}"] = str(acc)

    if isinstance(template_formula, str) and template_formula.startswith("="):
        ws["B2"] = template_formula
        last_row = len(accounts) + 1
        for r in range(3, last_row + 1):
            ws[f"B{r}"] = Translator(template_formula, origin="B2").translate_formula(f"B{r}")

    wb.save(CONCAT_PATH)

def build_cm_apply_details(df: pd.DataFrame) -> pd.DataFrame:
    data = df.copy()
    data["Class"] = data["Class"].apply(normalize_class)
    data["Account Number"] = data["Account Number"].astype(str).str.strip()
    data["Ledger"] = data["Ledger"].astype(str).str.strip()
    data["Operating Unit"] = data["Operating Unit"].astype(str).str.strip()
    data["Currency"] = data["Currency"].astype(str).str.strip()
    data["TRX DATE"] = pd.to_datetime(data["TRX DATE"], errors="coerce")
    data["GL Date"] = pd.to_datetime(data["GL Date"], errors="coerce")
    data["Open Balance"] = pd.to_numeric(data["Open Balance"], errors="coerce").fillna(0.0)
    data["_group_flag"] = data["TRX Type Name"].apply(is_group)

    rows = []
    # NOW GROUPING BY OPERATING UNIT TOO - ensures CM and target are in same OU
    for _, grp in data.groupby(["Account Number", "Ledger", "Operating Unit", "Currency"], dropna=False):
        cms = grp[grp["Class"] == "Credit Memo"].copy()
        targets = grp[grp["Class"].isin(["Invoice", "Debit Memo"])].copy()
        if cms.empty or targets.empty:
            continue

        cms = cms.sort_values(["TRX DATE", "GL Date", "Transaction Number"], kind="stable")
        targets = targets.sort_values(["TRX DATE", "GL Date", "Transaction Number"], kind="stable").copy()
        targets["remaining_to_apply"] = targets["Open Balance"].abs().round(2)

        for _, cm in cms.iterrows():
            cm_remaining = round(abs(to_num(cm["Open Balance"])), 2)
            if cm_remaining <= 0:
                continue

            eligible_mask = targets["remaining_to_apply"] > 0
            if cm["_group_flag"]:
                eligible_mask &= targets["_group_flag"]
            eligible = targets[eligible_mask]

            for t_idx, tgt in eligible.iterrows():
                if cm_remaining <= 0:
                    break

                tgt_remaining = round(to_num(targets.at[t_idx, "remaining_to_apply"]), 2)
                if tgt_remaining <= 0:
                    continue

                applied = round(min(cm_remaining, tgt_remaining), 2)
                if applied <= 0:
                    continue

                rows.append({
                    "Account Number": cm["Account Number"],
                    "Ledger": cm["Ledger"],
                    "Operating Unit": cm["Operating Unit"],
                    "Currency": cm["Currency"],
                    "Credit Memo Number": cm["Transaction Number"],
                    "Credit Memo Class": cm["Class"],
                    "Credit Memo TRX Type": cm["TRX Type Name"],
                    "Credit Memo Date": cm["TRX DATE"],
                    "Credit Memo Open Balance": round(to_num(cm["Open Balance"]), 2),
                    "Applied To Number": tgt["Transaction Number"],
                    "Applied To Class": tgt["Class"],
                    "Applied To TRX Type": tgt["TRX Type Name"],
                    "Applied To Date": tgt["TRX DATE"],
                    "Applied To Open Balance": round(to_num(tgt["Open Balance"]), 2),
                    "Applied Amount": applied,
                })

                cm_remaining = round(cm_remaining - applied, 2)
                targets.at[t_idx, "remaining_to_apply"] = round(tgt_remaining - applied, 2)

    out = pd.DataFrame(rows)
    if out.empty:
        return pd.DataFrame(columns=[
            "Account Number", "Ledger", "Operating Unit", "Currency", "Credit Memo Number", "Credit Memo Class",
            "Credit Memo TRX Type", "Credit Memo Date", "Credit Memo Open Balance",
            "Applied To Number", "Applied To Class", "Applied To TRX Type", "Applied To Date",
            "Applied To Open Balance", "Applied Amount"
        ])

    return out.sort_values(
        ["Account Number", "Ledger", "Operating Unit", "Currency", "Credit Memo Number", "Applied To Date", "Applied To Number"],
        kind="stable"
    ).reset_index(drop=True)

def get_currency_rates(conn) -> dict:
    """
    Fetch latest USD conversion rates from Oracle GL_DAILY_RATES.
    Returns dict: {currency_code: rate_to_usd}
    """
    try:
        df_rates = run_query(conn, CURRENCY_CONVERSION_QUERY)
        if df_rates.empty:
            print("[WARN] No currency rates found in GL_DAILY_RATES. Using 1.0 for all conversions.")
            return {}

        # Build dictionary: FROM_CURRENCY -> CONVERSION_RATE
        rates = {}
        for _, row in df_rates.iterrows():
            from_curr = str(row["FROM_CURRENCY"]).strip().upper()
            rate = float(row["CONVERSION_RATE"]) if pd.notna(row["CONVERSION_RATE"]) else 1.0
            rates[from_curr] = rate

        # USD to USD is always 1.0
        rates["USD"] = 1.0

        print(f"[INFO] Loaded {len(rates)} currency conversion rates from Oracle GL_DAILY_RATES")
        return rates
    except Exception as e:
        print(f"[ERROR] Failed to fetch currency rates: {e}")
        return {}

def convert_to_usd(amount: float, currency: str, rates: dict) -> float:
    """
    Convert amount to USD using provided rates dictionary.
    If currency not found, returns original amount (assumes 1.0 rate).
    """
    if pd.isna(amount):
        return 0.0

    curr_upper = str(currency).strip().upper()
    if curr_upper == "USD":
        return round(float(amount), 2)

    rate = rates.get(curr_upper, 1.0)
    return round(float(amount) * rate, 2)

def build_wo_summary_by_ou(df_wo_matches: pd.DataFrame, rates: dict) -> pd.DataFrame:
    """
    Creates summary showing WO reversals per Operating Unit:
    - Operating Unit
    - Transaction Count
    - Total Amount (Original Currency)
    - Total Amount USD
    """
    if df_wo_matches is None or df_wo_matches.empty:
        return pd.DataFrame(columns=[
            "Operating Unit", "Transaction Count", "Currency Summary", "Total Amount USD"
        ])

    df = df_wo_matches.copy()
    df["Operating Unit"] = df["Operating Unit"].astype(str).str.strip()
    df["Currency"] = df["Currency"].astype(str).str.strip()
    df["Applied Amount"] = pd.to_numeric(df["Applied Amount"], errors="coerce").fillna(0.0)

    # Convert all amounts to USD
    df["Applied Amount USD"] = df.apply(
        lambda row: convert_to_usd(row["Applied Amount"], row["Currency"], rates),
        axis=1
    )

    summary_rows = []

    for ou, ou_group in df.groupby("Operating Unit", dropna=False):
        # Count unique transactions
        trx_count = ou_group["WO Transaction Number"].nunique()

        # Build currency summary string (e.g., "EUR: 1,234.56 | GBP: 890.12")
        currency_totals = ou_group.groupby("Currency")["Applied Amount"].sum().round(2)
        currency_summary = " | ".join([f"{curr}: {amt:,.2f}" for curr, amt in currency_totals.items()])

        # Total USD
        total_usd = ou_group["Applied Amount USD"].sum()

        summary_rows.append({
            "Operating Unit": ou,
            "Transaction Count": trx_count,
            "Currency Summary": currency_summary,
            "Total Amount USD": round(total_usd, 2)
        })

    df_summary = pd.DataFrame(summary_rows)
    if df_summary.empty:
        return pd.DataFrame(columns=[
            "Operating Unit", "Transaction Count", "Currency Summary", "Total Amount USD"
        ])

    # Sort by USD amount descending
    df_summary = df_summary.sort_values("Total Amount USD", ascending=False).reset_index(drop=True)

    # Add grand total row
    grand_total = pd.DataFrame([{
        "Operating Unit": "GRAND TOTAL",
        "Transaction Count": df_summary["Transaction Count"].sum(),
        "Currency Summary": "—",
        "Total Amount USD": df_summary["Total Amount USD"].sum()
    }])

    df_summary = pd.concat([df_summary, grand_total], ignore_index=True)

    return df_summary

def build_wo_fallback(conn, source_df: pd.DataFrame, applied_df: pd.DataFrame):
    src = source_df.copy()
    src["Class"] = src["Class"].apply(normalize_class)
    src["Account Number"] = src["Account Number"].astype(str).str.strip()
    src["Operating Unit"] = src["Operating Unit"].astype(str).str.strip()
    src["Currency"] = src["Currency"].astype(str).str.strip()
    src["Open Balance"] = pd.to_numeric(src["Open Balance"], errors="coerce").fillna(0.0)
    src["TRX DATE"] = pd.to_datetime(src["TRX DATE"], errors="coerce")

    cm_accounts = set(src.loc[src["Class"] == "Credit Memo", "Account Number"].dropna().astype(str))
    matched_accounts = set(applied_df["Account Number"].dropna().astype(str)) if not applied_df.empty else set()
    pending_accounts = sorted(cm_accounts - matched_accounts)

    print(f"Pending accounts for WO: {len(pending_accounts)}")
    print("First pending accounts:", pending_accounts[:20])

    update_concat_for_unmatched(pending_accounts)

    raw_empty = pd.DataFrame(columns=[
        "Transaction Number", "Transaction Type", "Transaction Date", "Account Number", "Operating Unit",
        "Entered Currency", "Entered Amount", "Adjustment Number", "Reason Code"
    ])
    match_empty = pd.DataFrame(columns=[
        "Account Number", "Operating Unit", "Currency", "Credit Memo Number", "Credit Memo TRX Type",
        "Credit Memo Date", "Credit Memo Open Balance", "WO Transaction Number", "WO Transaction Type",
        "WO Transaction Date", "WO Entered Amount", "WO Reason Code", "Applied Amount"
    ])

    if not pending_accounts:
        return raw_empty, match_empty

    wo_parts = []
    for i in range(0, len(pending_accounts), 1000):
        acc_chunk = pending_accounts[i:i + 1000]
        placeholders = ", ".join(f":acc{j}" for j in range(len(acc_chunk)))
        sql = WO_PER_OID_QUERY.format(placeholders=placeholders)
        params = {f"acc{j}": v for j, v in enumerate(acc_chunk)}
        wo_parts.append(run_query(conn, sql, params))

    df_wo = pd.concat(wo_parts, ignore_index=True) if wo_parts else raw_empty.copy()
    df_wo = df_wo.drop_duplicates().reset_index(drop=True)

    print(f"WO raw rows returned: {len(df_wo)}")

    if df_wo.empty:
        return df_wo, match_empty

    df_wo["Account Number"] = df_wo["Account Number"].astype(str).str.strip()
    df_wo["Operating Unit"] = df_wo["Operating Unit"].astype(str).str.strip()
    df_wo["Entered Currency"] = df_wo["Entered Currency"].astype(str).str.strip()
    df_wo["Entered Amount"] = pd.to_numeric(df_wo["Entered Amount"], errors="coerce").fillna(0.0)
    df_wo["Transaction Date"] = pd.to_datetime(df_wo["Transaction Date"], errors="coerce")

    df_wo_group = df_wo[
        df_wo["Transaction Type"].astype(str).str.contains("GROUP", case=False, na=False)
    ].copy()

    unmatched_cms = src[
        (src["Class"] == "Credit Memo") &
        (src["Account Number"].isin(pending_accounts))
    ].copy()

    rows = []

    # NOW GROUPING BY OPERATING UNIT TOO - ensures CM and WO are in same OU
    for (account, ou, currency), cm_group in unmatched_cms.groupby(["Account Number", "Operating Unit", "Currency"], dropna=False):
        wo_group = df_wo_group[
            (df_wo_group["Account Number"] == account) &
            (df_wo_group["Operating Unit"] == ou) &
            (df_wo_group["Entered Currency"] == currency)
        ].copy()

        if wo_group.empty:
            continue

        cm_group = cm_group.sort_values(["TRX DATE", "Transaction Number"], kind="stable").copy()
        wo_group = wo_group.sort_values(["Transaction Date", "Transaction Number", "Adjustment Number"], kind="stable").copy()
        wo_group["remaining_wo_amount"] = wo_group["Entered Amount"].abs().round(2)

        for _, cm in cm_group.iterrows():
            cm_remaining = round(abs(to_num(cm["Open Balance"])), 2)
            if cm_remaining <= 0:
                continue

            for wo_idx, wo in wo_group.iterrows():
                if cm_remaining <= 0:
                    break

                wo_remaining = round(to_num(wo_group.at[wo_idx, "remaining_wo_amount"]), 2)
                if wo_remaining <= 0:
                    continue

                applied = round(min(cm_remaining, wo_remaining), 2)
                if applied <= 0:
                    continue

                rows.append({
                    "Account Number": cm["Account Number"],
                    "Operating Unit": cm["Operating Unit"],
                    "Currency": cm["Currency"],
                    "Credit Memo Number": cm["Transaction Number"],
                    "Credit Memo TRX Type": cm["TRX Type Name"],
                    "Credit Memo Date": cm["TRX DATE"],
                    "Credit Memo Open Balance": round(to_num(cm["Open Balance"]), 2),
                    "WO Transaction Number": wo["Transaction Number"],
                    "WO Transaction Type": wo["Transaction Type"],
                    "WO Transaction Date": wo["Transaction Date"],
                    "WO Entered Amount": round(to_num(wo["Entered Amount"]), 2),
                    "WO Reason Code": wo["Reason Code"],
                    "Applied Amount": applied,
                })

                cm_remaining = round(cm_remaining - applied, 2)
                wo_group.at[wo_idx, "remaining_wo_amount"] = round(wo_remaining - applied, 2)

    df_matches = pd.DataFrame(rows)
    if df_matches.empty:
        return df_wo, match_empty

    df_matches = df_matches.drop_duplicates().reset_index(drop=True)

    return df_wo, df_matches

def map_operating_unit(trx_type: str) -> str:
    if not isinstance(trx_type, str):
        return ""
    if trx_type.startswith("IT"):
        return "Venere Net S.r.l."
    if trx_type.startswith("CH"):
        return "12305 Expedia Lodging Partner Services Sarl"
    if trx_type.startswith("US"):
        return "11105 Expedia, Inc."
    if trx_type.startswith("TS"):
        return "14101 Travelscape, LLC"
    if trx_type.startswith("BR"):
        return "11115 Expedia do Brasil Agencia"
    return ""

def map_activity_name(oper_unit: str) -> str:
    if not isinstance(oper_unit, str):
        return ""

    ou = oper_unit.upper()
    if ou.startswith("12305"):
        return "CH WRITE-OFF BAD DEBT"
    if ou.startswith("14101"):
        return "TS WRITE-OFF BAD DEBT"
    if ou.startswith("11105"):
        return "US WRITE-OFF BAD DEBT"
    if ou.startswith("11115"):
        return "BR WRITE-OFF BAD DEBT"
    if "VENERE NET S.R.L." in ou:
        return "IT WRITE-OFF BAD DEBT"
    return ""

def normalize_reason(reason):
    if pd.isna(reason) or not isinstance(reason, str) or not reason.strip():
        return "Uneconomical to Collect"
    reason_clean = reason.strip().upper()
    overrides = {
        "UNECONOMICAL_TO_COLLECT": "Uneconomical to Collect",
        "SMALL_AMT_REMAINING": "Small Amt Remaining",
    }
    if reason_clean in overrides:
        return overrides[reason_clean]
    return reason_clean.replace("_", " ").title()

def build_csv_from_aba3(df_aba3: pd.DataFrame, out_dir: Path):
    if df_aba3 is None or df_aba3.empty:
        return None

    df_src = df_aba3.copy()
    df_src["WO Transaction Type"] = df_src["WO Transaction Type"].astype(str).str.strip()
    df_src["WO Transaction Number"] = df_src["WO Transaction Number"].astype(str).str.strip()
    df_src["WO Entered Amount"] = pd.to_numeric(df_src["WO Entered Amount"], errors="coerce").fillna(0.0)
    df_src["Applied Amount"] = pd.to_numeric(df_src["Applied Amount"], errors="coerce").fillna(0.0)
    df_src["WO Reason Code"] = df_src["WO Reason Code"].astype(str).str.strip()

    df_src = df_src[
        df_src["WO Transaction Type"].astype(str).str.contains("GROUP", case=False, na=False) &
        df_src["WO Transaction Number"].notna() &
        (df_src["WO Transaction Number"] != "") &
        (df_src["Applied Amount"] > 0)
    ].copy()

    if df_src.empty:
        return None

    today = dt.date.today()
    today_csv_name = today.strftime("%m%d%Y")
    today_comment = today.strftime("%m/%d/%Y")

    oper_units = df_src["WO Transaction Type"].map(map_operating_unit)

    df_csv = pd.DataFrame()
    df_csv["Index"] = range(1, len(df_src) + 1)
    df_csv["Operating Unit"] = oper_units
    df_csv["Transaction Number"] = df_src["WO Transaction Number"]
    df_csv["BFB Number"] = ""
    df_csv["Activity Name"] = oper_units.map(map_activity_name)
    df_csv["Adjustment Type"] = "Line"
    df_csv["Amount to be Adjusted"] = (-df_src["Applied Amount"]).round(2)
    df_csv["Reason"] = df_src["WO Reason Code"].apply(normalize_reason)
    df_csv["Comments"] = "180+ CM Group " + today_comment
    df_csv["GL Date"] = ""
    df_csv["Adjust Date"] = ""

    df_csv = df_csv.drop_duplicates().reset_index(drop=True)
    df_csv["Index"] = range(1, len(df_csv) + 1)

    csv_name = f"180CMGroup_WOperOID_{today_csv_name}.csv"
    csv_path = out_dir / csv_name
    df_csv.to_csv(csv_path, index=False, encoding="cp1252")
    return csv_path

def clear_apply_credit_memo_data(ws, start_row=11, end_col=21):

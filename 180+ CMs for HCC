def write_df(ws, df: pd.DataFrame):
    ws.delete_rows(1, ws.max_row)
    headers = list(df.columns)

    for c_idx, col in enumerate(headers, start=1):
        cell = ws.cell(1, c_idx, col)
        cell.font = Font(name="Arial", bold=True)

    for r_idx, row in enumerate(df.itertuples(index=False), start=2):
        for c_idx, value in enumerate(row, start=1):
            cell = ws.cell(r_idx, c_idx, value)
            cell.font = Font(name="Arial")
            if isinstance(value, (pd.Timestamp, dt.datetime, dt.date)):
                cell.number_format = "mm/dd/yyyy"

    autosize(ws)
    ws.freeze_panes = "A2"

def autosize(ws):
    for col_cells in ws.columns:
        max_len = 0
        col_letter = get_column_letter(col_cells[0].column)
        for cell in col_cells:
            try:
                val = "" if cell.value is None else str(cell.value)
            except Exception:
                val = ""
            max_len = max(max_len, len(val))
        ws.column_dimensions[col_letter].width = min(max(max_len + 2, 12), 40)

def ensure_workbook(path: Path):
    if path.exists():
        return load_workbook(path)
    wb = Workbook()
    wb.save(path)
    return load_workbook(path)

def replace_or_create_sheet(wb, name: str):
    if name in wb.sheetnames:
        return wb[name]
    return wb.create_sheet(title=name)

def main():
    if not PASSWORD or PASSWORD == "CHANGE_ME":
        raise ValueError("Atualize ORACLE_PASSWORD antes de rodar o script.")

    if not M4APPS_TEMPLATE.exists():

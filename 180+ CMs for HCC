CURRENCY_CONVERSION_QUERY = r"""
SELECT DISTINCT
    GDR.FROM_CURRENCY,
    GDR.TO_CURRENCY,
    GDR.CONVERSION_RATE,
    GDR.CONVERSION_DATE
FROM APPS.GL_DAILY_RATES GDR
WHERE GDR.TO_CURRENCY = 'USD'
  AND GDR.CONVERSION_TYPE = 'Corporate'
  AND GDR.CONVERSION_DATE = (
      SELECT MAX(GDR2.CONVERSION_DATE)
      FROM APPS.GL_DAILY_RATES GDR2
      WHERE GDR2.FROM_CURRENCY = GDR.FROM_CURRENCY
        AND GDR2.TO_CURRENCY = 'USD'

    WORK_DIR.mkdir(parents=True, exist_ok=True)
    run_dir = make_run_dir(WORK_DIR)
    output_xlsx = output_workbook_path(run_dir)

    init_oracle()

    with oracledb.connect(user=USERNAME, password=PASSWORD, dsn=DSN) as conn:
        with conn.cursor() as cur:
            cur.execute("ALTER SESSION SET CURRENT_SCHEMA = APPS")

        # Fetch currency conversion rates
        print("[INFO] Fetching currency conversion rates from Oracle GL_DAILY_RATES...")
        currency_rates = get_currency_rates(conn)

        df_tab1 = run_query(conn, PRIMARY_QUERY_180_CM_GROUP)
